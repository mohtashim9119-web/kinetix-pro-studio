{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kinetix Pro Studio",
  "version": "0.1.0",
  "identifier": "com.kinetix.pro-studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kinetix Pro Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/whisper"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
